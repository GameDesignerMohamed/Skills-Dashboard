    "toolSlug": "Slack_SearchMessages",
    "toolPurpose": "Search messages across the workspace using Slack's search syntax. Supports queries with modifiers like from:, in:, has:, before:, after:, and boolean operators.",
    "created_by": "human",
    "httpMethod": "GET",
    "endpoint": "/search.messages",
    "parameters": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Search query string. Supports Slack search modifiers (e.g., 'from:@user in:#channel has:link budget report')"
        },
        "count": {
          "type": "integer",
          "description": "Number of results per page (1-100)",
          "minimum": 1,
          "maximum": 100,
          "default": 20
        },
        "page": {
          "type": "integer",
          "description": "Page number for pagination",
          "default": 1
        },
        "sort": {
          "type": "string",
          "description": "Sort order for results",
          "enum": ["score", "timestamp"],
          "default": "score"
        },
        "sort_dir": {
          "type": "string",
          "description": "Sort direction",
          "enum": ["asc", "desc"],
          "default": "desc"
        }
      },
      "required": ["query"]
    },
    "inputsSpec": {
      "required": ["query"],
      "optional": ["count", "page", "sort", "sort_dir"]
    }
  },
