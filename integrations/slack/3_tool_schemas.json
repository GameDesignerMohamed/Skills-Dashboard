    "toolSlug": "Slack_ListConversations",
    "toolPurpose": "List channels (public, private, DMs, group DMs) in a Slack workspace with pagination. Returns channel name, topic, purpose, member count, and archive status.",
    "created_by": "human",
    "httpMethod": "GET",
    "endpoint": "/conversations.list",
    "parameters": {
      "type": "object",
      "properties": {
        "types": {
          "type": "string",
          "description": "Comma-separated channel types to include: public_channel, private_channel, mpim, im",
          "default": "public_channel,private_channel"
        },
        "limit": {
          "type": "integer",
          "description": "Number of channels to return per page (1-1000)",
          "minimum": 1,
          "maximum": 1000,
          "default": 200
        },
        "cursor": {
          "type": "string",
          "description": "Pagination cursor from previous response's response_metadata.next_cursor"
        },
        "exclude_archived": {
          "type": "boolean",
          "description": "Exclude archived channels from results",
          "default": true
        }
      },
      "required": []
    },
    "inputsSpec": {
      "required": [],
      "optional": ["types", "limit", "cursor", "exclude_archived"]
    }
  },
