    "toolSlug": "Slack_GetHistory",
    "toolPurpose": "Retrieve message history from a conversation (channel, DM, or group DM). Returns messages with text, author, timestamps, thread metadata, reactions, and file attachments.",
    "created_by": "human",
    "httpMethod": "GET",
    "endpoint": "/conversations.history",
    "parameters": {
      "type": "object",
      "properties": {
        "channel": {
          "type": "string",
          "description": "Channel ID (e.g., 'C024BE91L')"
        },
        "limit": {
          "type": "integer",
          "description": "Number of messages to return (1-1000)",
          "minimum": 1,
          "maximum": 1000,
          "default": 100
        },
        "cursor": {
          "type": "string",
          "description": "Pagination cursor from previous response"
        },
        "oldest": {
          "type": "string",
          "description": "Only messages after this Unix timestamp (inclusive)"
        },
        "latest": {
          "type": "string",
          "description": "Only messages before this Unix timestamp (exclusive)"
        },
        "inclusive": {
          "type": "boolean",
          "description": "Include messages with oldest or latest timestamps",
          "default": false
        }
      },
      "required": ["channel"]
    },
    "inputsSpec": {
      "required": ["channel"],
      "optional": ["limit", "cursor", "oldest", "latest", "inclusive"]
    }
  },
  {
    "toolSlug": "Slack_PostMessage",
    "toolPurpose": "Send a message to a channel or thread. Supports plain text, rich-text blocks, and threaded replies. WRITE operation — requires explicit Mind confirmation before execution.",
    "created_by": "human",
    "httpMethod": "POST",
    "endpoint": "/chat.postMessage",
    "parameters": {
      "type": "object",
      "properties": {
        "channel": {
          "type": "string",
          "description": "Channel ID to post the message to"
        },
        "text": {
          "type": "string",
          "description": "The message text (supports Slack mrkdwn formatting). Also serves as fallback for blocks."
        },
        "blocks": {
          "type": "array",
          "description": "Array of Block Kit layout blocks for rich formatting",
          "items": {
            "type": "object"
          }
        },
        "thread_ts": {
          "type": "string",
          "description": "Timestamp of parent message to reply in thread"
        },
        "reply_broadcast": {
          "type": "boolean",
          "description": "When replying in thread, also post to channel",
          "default": false
        },
        "unfurl_links": {
          "type": "boolean",
          "description": "Enable URL unfurling in the message",
          "default": true
        }
      },
      "required": ["channel", "text"]
    },
    "inputsSpec": {
      "required": ["channel", "text"],
      "optional": ["blocks", "thread_ts", "reply_broadcast", "unfurl_links"]
    }
  },
