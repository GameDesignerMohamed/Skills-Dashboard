[
  {
    "toolSlug": "Notion_SearchPages",
    "toolPurpose": "Search across all pages and databases in the connected Notion workspace by query string.",
    "created_by": "human",
    "parameters": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Search query to find pages or databases by title or content"
        },
        "filter_type": {
          "type": "string",
          "description": "Filter results by object type",
          "enum": ["page", "database"]
        },
        "sort_direction": {
          "type": "string",
          "description": "Sort by last edited time",
          "enum": ["ascending", "descending"]
        },
        "page_size": {
          "type": "integer",
          "description": "Number of results to return",
          "maximum": 100
        }
      },
      "required": ["query"]
    },
    "inputsSpec": {
      "required": ["query"],
      "optional": ["filter_type", "sort_direction", "page_size"]
    }
  },
  {
    "toolSlug": "Notion_GetPage",
    "toolPurpose": "Retrieve the full content and properties of a specific Notion page by its ID.",
    "created_by": "human",
    "parameters": {
      "type": "object",
      "properties": {
        "page_id": {
          "type": "string",
          "description": "The unique identifier of the Notion page (UUID format)"
        },
        "include_children": {
          "type": "boolean",
          "description": "Whether to retrieve all child blocks (full page content)"
        }
      },
      "required": ["page_id"]
    },
    "inputsSpec": {
      "required": ["page_id"],
      "optional": ["include_children"]
    }
  },
  {
    "toolSlug": "Notion_CreatePage",
    "toolPurpose": "Create a new page in a specified Notion parent page or database.",
    "created_by": "human",
    "parameters": {
      "type": "object",
      "properties": {
        "parent_id": {
          "type": "string",
          "description": "ID of the parent page or database where the new page will be created"
        },
        "parent_type": {
          "type": "string",
          "description": "Whether the parent is a page or database",
          "enum": ["page_id", "database_id"]
        },
        "title": {
          "type": "string",
          "description": "Title of the new page"
        },
        "content_blocks": {
          "type": "array",
          "description": "Array of Notion block objects defining the page content",
          "items": { "type": "object" }
        },
        "properties": {
          "type": "object",
          "description": "Database properties to set if parent is a database"
        }
      },
      "required": ["parent_id", "parent_type", "title"]
    },
    "inputsSpec": {
      "required": ["parent_id", "parent_type", "title"],
      "optional": ["content_blocks", "properties"]
    }
  },
  {
    "toolSlug": "Notion_UpdatePage",
    "toolPurpose": "Update properties or append content blocks to an existing Notion page.",
    "created_by": "human",
    "parameters": {
      "type": "object",
      "properties": {
        "page_id": {
          "type": "string",
          "description": "The unique identifier of the page to update"
        },
        "properties": {
          "type": "object",
          "description": "Page properties to update (for database entries)"
        },
        "append_blocks": {
          "type": "array",
          "description": "New content blocks to append to the page",
          "items": { "type": "object" }
        },
        "archived": {
          "type": "boolean",
          "description": "Set to true to archive/delete the page"
        }
      },
      "required": ["page_id"]
    },
    "inputsSpec": {
      "required": ["page_id"],
      "optional": ["properties", "append_blocks", "archived"]
    }
  },
  {
    "toolSlug": "Notion_QueryDatabase",
    "toolPurpose": "Query a Notion database with filters, sorts, and pagination to retrieve matching entries.",
    "created_by": "human",
    "parameters": {
      "type": "object",
      "properties": {
        "database_id": {
          "type": "string",
          "description": "The unique identifier of the Notion database to query"
        },
        "filter": {
          "type": "object",
          "description": "Notion filter object to narrow results (supports compound and/or filters)"
        },
        "sorts": {
          "type": "array",
          "description": "Array of sort objects defining result ordering",
          "items": {
            "type": "object",
            "properties": {
              "property": { "type": "string" },
              "direction": { "type": "string", "enum": ["ascending", "descending"] }
            }
          }
        },
        "page_size": {
          "type": "integer",
          "description": "Number of results per page",
          "maximum": 100
        },
        "start_cursor": {
          "type": "string",
          "description": "Pagination cursor from a previous query"
        }
      },
      "required": ["database_id"]
    },
    "inputsSpec": {
      "required": ["database_id"],
      "optional": ["filter", "sorts", "page_size", "start_cursor"]
    }
  },
  {
    "toolSlug": "Notion_GetDatabaseSchema",
    "toolPurpose": "Retrieve the schema (properties and their types) of a Notion database for understanding its structure.",
    "created_by": "human",
    "parameters": {
      "type": "object",
      "properties": {
        "database_id": {
          "type": "string",
          "description": "The unique identifier of the Notion database"
        }
      },
      "required": ["database_id"]
    },
    "inputsSpec": {
      "required": ["database_id"],
      "optional": []
    }
  }
