  {
    "toolSlug": "PandaDoc_CreateDocumentFromTemplate",
    "toolPurpose": "Create a new document from an existing PandaDoc template with field mapping and recipient configuration.",
    "created_by": "human",
    "parameters": {
      "type": "object",
      "properties": {
        "template_id": {
          "type": "string",
          "description": "PandaDoc template ID to use for document creation"
        },
        "name": {
          "type": "string",
          "description": "Document name/title"
        },
        "recipients": {
          "type": "array",
          "description": "Array of recipient objects for the document",
          "items": {
            "type": "object",
            "properties": {
              "email": {
                "type": "string",
                "description": "Recipient email address"
              },
              "name": {
                "type": "string",
                "description": "Recipient full name"
              },
              "role": {
                "type": "string",
                "description": "Recipient role (e.g., 'signer', 'cc')"
              }
            },
            "required": ["email"]
          }
        },
        "fields": {
          "type": "object",
          "description": "Document field values to populate (key-value pairs for template variables)",
          "additionalProperties": { "type": "string" }
        },
        "metadata": {
          "type": "object",
          "description": "Custom metadata to attach to the document",
          "additionalProperties": { "type": "string" }
        }
      },
      "required": ["template_id", "name"]
    },
    "inputsSpec": {
      "required": ["template_id", "name"],
      "optional": ["recipients", "fields", "metadata"]
    }
  },
  {
