  {
    "toolSlug": "PandaDoc_ListDocuments",
    "toolPurpose": "Retrieve documents from PandaDoc workspace with optional filters by status, tag, or folder.",
    "created_by": "human",
    "parameters": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "description": "Filter documents by status",
          "enum": ["draft", "sent", "viewed", "completed", "declined", "expired"]
        },
        "tag": {
          "type": "string",
          "description": "Filter documents by tag name"
        },
        "folder": {
          "type": "string",
          "description": "Filter documents by folder ID"
        },
        "count": {
          "type": "integer",
          "description": "Number of documents to retrieve (default: 20, max: 100)",
          "minimum": 1,
          "maximum": 100
        },
        "offset": {
          "type": "integer",
          "description": "Pagination offset for document results (default: 0)",
          "minimum": 0
        }
      },
      "required": []
    },
    "inputsSpec": {
      "required": [],
      "optional": ["status", "tag", "folder", "count", "offset"]
    }
  },
