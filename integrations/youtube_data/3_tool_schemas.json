[
  {
    "toolSlug": "YouTube_SearchVideos",
    "toolPurpose": "Search YouTube for videos, channels, or playlists matching a query with advanced filters.",
    "created_by": "human",
    "parameters": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Search query string"
        },
        "type": {
          "type": "string",
          "description": "Type of resource to search for",
          "enum": ["video", "channel", "playlist"]
        },
        "max_results": {
          "type": "integer",
          "description": "Maximum number of results (1-50)",
          "maximum": 50
        },
        "order": {
          "type": "string",
          "description": "Sort order for results",
          "enum": ["relevance", "date", "rating", "viewCount", "title"]
        },
        "published_after": {
          "type": "string",
          "description": "ISO 8601 datetime — only return results published after this date"
        },
        "published_before": {
          "type": "string",
          "description": "ISO 8601 datetime — only return results published before this date"
        },
        "region_code": {
          "type": "string",
          "description": "ISO 3166-1 alpha-2 country code for region-specific results"
        },
        "page_token": {
          "type": "string",
          "description": "Pagination token from a previous search response"
        }
      },
      "required": ["query"]
    },
    "inputsSpec": {
      "required": ["query"],
      "optional": ["type", "max_results", "order", "published_after", "published_before", "region_code", "page_token"]
    }
  },
