[
  {
    "toolSlug": "Zoom_ListMeetings",
    "toolPurpose": "Retrieve all scheduled meetings for a specific user, with optional pagination and status filtering.",
    "created_by": "human",
    "httpMethod": "GET",
    "endpoint": "/users/{userId}/meetings",
    "parameters": {
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The user ID for which to list meetings (typically 'me' for authenticated user)"
        },
        "type": {
          "type": "string",
          "description": "Meeting type filter: 'scheduled', 'live', 'upcoming', or 'previous'",
          "enum": ["scheduled", "live", "upcoming", "previous"]
        },
        "page_size": {
          "type": "integer",
          "description": "Number of meetings to return (default: 30, max: 300)",
          "minimum": 1,
          "maximum": 300,
          "default": 30
        },
        "page_number": {
          "type": "integer",
          "description": "Page number for pagination",
          "minimum": 1,
          "default": 1
        }
      },
      "required": ["userId"]
    },
    "inputsSpec": {
      "required": ["userId"],
      "optional": ["type", "page_size", "page_number"]
    }
  },
  {
