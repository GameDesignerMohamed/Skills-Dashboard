      "optional": ["occurrence_id"]
    }
  },
  {
    "toolSlug": "Zoom_CreateMeeting",
    "toolPurpose": "Schedule a new meeting for a user with topic, start time, duration, and meeting settings.",
    "created_by": "human",
    "httpMethod": "POST",
    "endpoint": "/users/{userId}/meetings",
    "parameters": {
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The user ID for which to create the meeting (typically 'me' for authenticated user)"
        },
        "topic": {
          "type": "string",
          "description": "Meeting title/topic"
        },
        "type": {
          "type": "integer",
          "description": "Meeting type: 1 (instant), 2 (scheduled), 3 (recurring without fixed repeat), 8 (recurring with fixed repeat)",
          "enum": [1, 2, 3, 8]
        },
        "start_time": {
          "type": "string",
          "description": "Meeting start time in ISO 8601 format (YYYY-MM-DDTHH:MM:SS or YYYY-MM-DDTHH:MM:SSZ)"
        },
        "duration": {
          "type": "integer",
          "description": "Meeting duration in minutes"
        },
        "timezone": {
          "type": "string",
          "description": "Timezone for the meeting (IANA timezone format, e.g., 'America/New_York')"
        },
        "password": {
          "type": "string",
          "description": "Meeting password for security"
        },
        "agenda": {
          "type": "string",
          "description": "Meeting agenda/description"
        },
        "settings": {
          "type": "object",
          "description": "Meeting settings (host_video, participant_video, join_before_host, mute_upon_entry, waiting_room, auto_recording, etc.)",
          "properties": {
            "host_video": {
              "type": "boolean",
              "description": "Whether host video is on"
            },
            "participant_video": {
              "type": "boolean",
              "description": "Whether participants can have video on"
            },
            "join_before_host": {
              "type": "boolean",
              "description": "Whether participants can join before host"
            },
            "mute_upon_entry": {
              "type": "boolean",
              "description": "Whether participants are muted upon entry"
            },
            "waiting_room": {
              "type": "boolean",
              "description": "Whether waiting room is enabled"
            },
            "auto_recording": {
              "type": "string",
              "description": "Auto-record setting: 'none', 'local', or 'cloud'",
              "enum": ["none", "local", "cloud"]
            }
          }
        },
        "recurrence": {
          "type": "object",
          "description": "Recurrence pattern for recurring meetings",
          "properties": {
            "type": {
              "type": "integer",
              "description": "Recurrence type: 1 (daily), 2 (weekly), 3 (monthly)",
              "enum": [1, 2, 3]
            },
            "repeat_interval": {
              "type": "integer",
              "description": "Repeat interval"
            },
            "end_times": {
              "type": "integer",
              "description": "Number of occurrences"
            },
            "end_date_time": {
              "type": "string",
              "description": "End date/time for recurrence in ISO 8601 format"
            }
          }
        }
      },
      "required": ["userId", "topic", "type"]
    },
    "inputsSpec": {
      "required": ["userId", "topic", "type"],
      "optional": ["start_time", "duration", "timezone", "password", "agenda", "settings", "recurrence"]
    }
  },
