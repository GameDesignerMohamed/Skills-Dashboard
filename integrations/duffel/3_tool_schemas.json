[
  {
    "toolSlug": "Duffel_CreateOfferRequest",
    "toolPurpose": "Create a flight search request with origin, destination, dates, passengers, and cabin class.",
    "created_by": "human",
    "httpMethod": "POST",
    "endpoint": "/air/offer_requests",
    "parameters": {
      "type": "object",
      "properties": {
        "slices": {
          "type": "array",
          "description": "Flight segments",
          "items": {
            "type": "object",
            "properties": {
              "origin": {
                "type": "string",
                "description": "IATA origin airport code"
              },
              "destination": {
                "type": "string",
                "description": "IATA destination airport code"
              },
              "departure_date": {
                "type": "string",
                "description": "Departure date (YYYY-MM-DD)"
              }
            },
            "required": [
              "origin",
              "destination",
              "departure_date"
            ]
          }
        },
        "passengers": {
          "type": "array",
          "description": "Passenger list",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "description": "Passenger type",
                "enum": [
                  "adult",
                  "child",
                  "infant_without_seat"
                ]
              }
            },
            "required": [
              "type"
            ]
          }
        },
        "cabin_class": {
          "type": "string",
          "description": "Preferred cabin",
          "enum": [
            "economy",
            "premium_economy",
            "business",
            "first"
          ]
        },
        "return_offers": {
          "type": "boolean",
          "description": "Return offers inline (recommended false for large searches)",
          "default": false
        }
      },
      "required": [
        "slices",
        "passengers"
      ]
    },
    "inputsSpec": {
      "required": [
        "slices",
        "passengers"
      ],
      "optional": [
        "cabin_class",
        "return_offers"
      ]
    }
  },
  {
    "toolSlug": "Duffel_ListOffers",
    "toolPurpose": "List available flight offers from a previously created offer request.",
    "created_by": "human",
    "httpMethod": "GET",
    "endpoint": "/air/offers",
    "parameters": {
      "type": "object",
      "properties": {
        "offer_request_id": {
          "type": "string",
          "description": "Offer request ID from CreateOfferRequest"
        },
        "sort": {
          "type": "string",
          "description": "Sort order",
          "enum": [
            "total_amount",
            "total_duration"
          ]
        },
        "max_connections": {
          "type": "integer",
          "description": "Maximum number of connections (0 for direct only)",
          "minimum": 0,
          "maximum": 3
        }
      },
      "required": [
        "offer_request_id"
      ]
    },
    "inputsSpec": {
      "required": [
        "offer_request_id"
      ],
      "optional": [
        "sort",
        "max_connections"
      ]
    }
  },
