        }
      },
      "required": ["site_id", "title", "content"]
    },
    "inputsSpec": {
      "required": ["site_id", "title", "content"],
      "optional": ["status", "categories", "tags", "excerpt", "featured_image_url", "scheduled_date"]
    }
  },
