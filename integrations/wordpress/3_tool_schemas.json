  {
    "toolSlug": "WordPress_ListPosts",
    "toolPurpose": "Retrieve posts from a WordPress site with optional filters by status, category, tag, search query, or pagination.",
    "created_by": "human",
    "parameters": {
      "type": "object",
      "properties": {
        "site_id": {
          "type": "string",
          "description": "WordPress.com site ID or domain (e.g., 'example.wordpress.com' or numeric site ID)"
        },
        "status": {
          "type": "string",
          "description": "Filter posts by status",
          "enum": ["publish", "draft", "pending", "private", "trash", "scheduled"]
        },
        "category": {
          "type": "string",
          "description": "Filter posts by category slug or ID"
        },
        "tag": {
          "type": "string",
          "description": "Filter posts by tag slug or ID"
        },
        "search": {
          "type": "string",
          "description": "Search posts by title or content"
        },
        "number": {
          "type": "integer",
          "description": "Number of posts to retrieve (default: 20, max: 100)",
          "minimum": 1,
          "maximum": 100
        },
        "offset": {
          "type": "integer",
          "description": "Pagination offset for retrieving additional posts",
          "minimum": 0
        }
      },
      "required": ["site_id"]
    },
    "inputsSpec": {
      "required": ["site_id"],
      "optional": ["status", "category", "tag", "search", "number", "offset"]
    }
  },
