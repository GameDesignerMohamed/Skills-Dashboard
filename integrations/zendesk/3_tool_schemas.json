    "toolSlug": "Zendesk_SearchTickets",
    "toolPurpose": "Search tickets using Zendesk Query Language (ZQL) with support for complex filters on status, assignee, requester, priority, and custom fields.",
    "created_by": "human",
    "parameters": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "ZQL query string for searching tickets (e.g., 'status:open assignee:me', 'priority:high created>2026-03-01', 'subject:urgent')"
        },
        "sort_by": {
          "type": "string",
          "description": "Field to sort by (default: 'created_at')",
          "enum": ["created_at", "updated_at", "status", "priority"]
        },
        "sort_order": {
          "type": "string",
          "description": "Sort order direction",
          "enum": ["asc", "desc"]
        },
        "limit": {
          "type": "integer",
          "description": "Maximum number of results to return (default: 25, max: 100)",
          "minimum": 1,
          "maximum": 100
        }
      },
      "required": ["query"]
    },
    "inputsSpec": {
      "required": ["query"],
      "optional": ["sort_by", "sort_order", "limit"]
    }
  },
