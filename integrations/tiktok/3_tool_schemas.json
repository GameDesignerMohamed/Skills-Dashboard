          "minimum": 1,
          "maximum": 100
        },
        "cursor": {
          "type": "string",
          "description": "Pagination cursor from previous response for fetching next batch of videos"
        },
        "fields": {
          "type": "array",
          "description": "Fields to retrieve for each video",
          "items": { "type": "string" },
          "enum": [
            "id",
            "create_time",
            "video_description",
            "duration",
            "height",
            "width",
            "title",
            "cover_image_url",
            "share_url",
            "view_count",
            "like_count",
            "comment_count",
            "share_count"
          ]
        }
      },
      "required": []
    },
    "inputsSpec": {
      "required": [],
      "optional": ["max_count", "cursor", "fields"]
    }
  },
  {
    "toolSlug": "TikTok_QueryVideos",
    "toolPurpose": "Query specific TikTok videos by their IDs to retrieve detailed metadata and engagement metrics. Returns video details, statistics, and content information.",
    "created_by": "human",
    "httpMethod": "POST",
    "endpoint": "/video/query/",
    "parameters": {
      "type": "object",
      "properties": {
        "video_ids": {
          "type": "array",
          "description": "Array of video IDs to query (maximum 20 IDs per request)",
          "items": { "type": "string" },
          "minItems": 1,
          "maxItems": 20
        },
        "fields": {
          "type": "array",
          "description": "Specific fields to retrieve for each video",
          "items": { "type": "string" },
          "enum": [
            "id",
            "create_time",
            "video_description",
            "duration",
            "height",
            "width",
            "title",
            "cover_image_url",
            "share_url",
            "view_count",
            "like_count",
            "comment_count",
            "share_count",
            "transcribe_status",
            "transcription_text"
          ]
        }
      },
      "required": ["video_ids"]
    },
    "inputsSpec": {
      "required": ["video_ids"],
      "optional": ["fields"]
    }
  },
  {
