[
  {
    "toolSlug": "Airtable_ListRecords",
    "toolPurpose": "Retrieve records from a table with optional filtering by formula, sorting, field selection, and pagination limits.",
    "created_by": "human",
    "parameters": {
      "type": "object",
      "properties": {
        "base_id": {
          "type": "string",
          "description": "Airtable base ID (e.g., appXxxxxxxxxxxx)"
        },
        "table_name": {
          "type": "string",
          "description": "Name or ID of the table to query"
        },
        "filterByFormula": {
          "type": "string",
          "description": "Airtable formula to filter records (e.g., '{Status} = \"Active\"', '{Created} > TODAY())')"
        },
        "sort": {
          "type": "array",
          "description": "Array of sort specifications. Each sort object has 'field' (string) and 'direction' (asc/desc)",
          "items": {
            "type": "object",
            "properties": {
              "field": {
                "type": "string",
                "description": "Field name to sort by"
              },
              "direction": {
                "type": "string",
                "enum": ["asc", "desc"],
                "description": "Sort direction"
              }
            },
            "required": ["field"]
          }
        },
        "fields": {
          "type": "array",
          "description": "Array of field names to retrieve (if omitted, all fields returned)",
          "items": { "type": "string" }
        },
        "maxRecords": {
          "type": "integer",
          "description": "Maximum number of records to return (default: 100, max: 100 per page)"
        }
      },
      "required": ["base_id", "table_name"]
    },
    "inputsSpec": {
      "required": ["base_id", "table_name"],
      "optional": ["filterByFormula", "sort", "fields", "maxRecords"]
    }
  },
