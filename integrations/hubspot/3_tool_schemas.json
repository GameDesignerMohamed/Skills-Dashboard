  {
    "toolSlug": "HubSpot_SearchContacts",
    "toolPurpose": "Search for contacts in HubSpot by email, name, or custom properties using advanced filtering.",
    "created_by": "human",
    "httpMethod": "POST",
    "endpoint": "/crm/v3/objects/contacts/search",
    "parameters": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Search query string (email, first name, last name, or phone number)"
        },
        "filters": {
          "type": "array",
          "description": "Array of filter objects for advanced property filtering",
          "items": {
            "type": "object",
            "properties": {
              "propertyName": {
                "type": "string",
                "description": "HubSpot property name (e.g., 'firstname', 'lastname', 'email', 'lifecyclestage')"
              },
              "operator": {
                "type": "string",
                "description": "Filter operator (EQ, NEQ, LT, LTE, GT, GTE, CONTAINS, NOT_CONTAINS, IN, NOT_IN, BETWEEN, EXISTS, NOT_EXISTS)",
                "enum": ["EQ", "NEQ", "LT", "LTE", "GT", "GTE", "CONTAINS", "NOT_CONTAINS", "IN", "NOT_IN", "BETWEEN", "EXISTS", "NOT_EXISTS"]
              },
              "value": {
                "description": "Filter value (string, number, or array depending on operator)"
              }
            },
            "required": ["propertyName", "operator"]
          }
        },
        "properties": {
          "type": "array",
          "description": "Specific contact properties to return (e.g., ['firstname', 'lastname', 'email', 'phone', 'lifecyclestage', 'company'])",
          "items": {
            "type": "string"
          }
        },
        "limit": {
          "type": "integer",
          "description": "Maximum number of results to return (1-100, default 10)",
          "minimum": 1,
          "maximum": 100,
          "default": 10
        },
        "after": {
          "type": "string",
          "description": "Pagination cursor for retrieving next page of results"
        }
      },
      "required": []
    },
    "inputsSpec": {
      "required": [],
      "optional": ["query", "filters", "properties", "limit", "after"]
    }
  },
