    "toolSlug": "Etsy_SearchListings",
    "toolPurpose": "Search active Etsy listings by keywords, category, sort order, and pagination. Returns listing IDs, titles, prices, and shop information.",
    "created_by": "human",
    "parameters": {
      "type": "object",
      "properties": {
        "keywords": {
          "type": "string",
          "description": "Search query string for listing titles and descriptions (required for search)"
        },
        "taxonomy_id": {
          "type": "integer",
          "description": "Filter by Etsy taxonomy category ID (e.g., 697 for Art, 1775 for Jewelry). Optional."
        },
        "sort_on": {
          "type": "string",
          "description": "Sort results by field",
          "enum": ["created", "down", "up", "favorite_count", "relevance"]
        },
        "sort_order": {
          "type": "string",
          "description": "Sort direction",
          "enum": ["asc", "desc"]
        },
        "limit": {
          "type": "integer",
          "description": "Maximum number of results to return (1-100, default 25)",
          "minimum": 1,
          "maximum": 100,
          "default": 25
        },
        "offset": {
          "type": "integer",
          "description": "Pagination offset - number of results to skip (default 0)",
          "minimum": 0,
          "default": 0
        }
      },
      "required": ["keywords"]
    },
    "inputsSpec": {
      "required": ["keywords"],
      "optional": ["taxonomy_id", "sort_on", "sort_order", "limit", "offset"]
    }
  },
