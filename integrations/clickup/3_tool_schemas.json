          "description": "Updated task description"
        },
        "assignees": {
          "type": "array",
          "description": "Updated array of assignee user IDs (replaces existing assignees)",
          "items": { "type": "string" }
        },
        "priority": {
          "type": "integer",
          "description": "Updated priority (1=urgent, 2=high, 3=medium, 4=low)",
          "minimum": 1,
          "maximum": 4
        },
        "due_date": {
          "type": "string",
          "description": "Updated due date in YYYY-MM-DD format or Unix timestamp in milliseconds"
        },
        "status": {
          "type": "string",
          "description": "Updated task status"
        }
      },
      "required": ["task_id"]
    },
    "inputsSpec": {
      "required": ["task_id"],
      "optional": ["name", "description", "assignees", "priority", "due_date", "status"]
    }
  },
