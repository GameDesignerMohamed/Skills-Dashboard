[
  {
    "toolSlug": "ClickUp_GetTasks",
    "toolPurpose": "Retrieve all tasks in a ClickUp list with optional filters by status, assignee, priority, or due date.",
    "created_by": "human",
    "parameters": {
      "type": "object",
      "properties": {
        "list_id": {
          "type": "string",
          "description": "ClickUp list ID to retrieve tasks from"
        },
        "archived": {
          "type": "boolean",
          "description": "Include archived tasks (default: false)"
        },
        "assignee": {
          "type": "string",
          "description": "Filter tasks by assignee user ID"
        },
        "status": {
          "type": "string",
          "description": "Filter tasks by status name (e.g., 'to do', 'in progress', 'done')"
        },
        "priority": {
          "type": "integer",
          "description": "Filter tasks by priority (1=urgent, 2=high, 3=medium, 4=low)",
          "minimum": 1,
          "maximum": 4
        },
        "page": {
          "type": "integer",
          "description": "Pagination page number (default: 0)"
        }
      },
      "required": ["list_id"]
    },
    "inputsSpec": {
      "required": ["list_id"],
      "optional": ["archived", "assignee", "status", "priority", "page"]
    }
  },
  {
    "toolSlug": "ClickUp_GetTask",
    "toolPurpose": "Retrieve detailed information about a specific ClickUp task including assignments, due dates, comments, and custom fields.",
    "created_by": "human",
    "parameters": {
      "type": "object",
      "properties": {
        "task_id": {
          "type": "string",
          "description": "ClickUp task ID to retrieve"
        },
        "include_comments": {
          "type": "boolean",
          "description": "Include task comments in response (default: false)"
        },
        "include_custom_fields": {
          "type": "boolean",
          "description": "Include custom field values (default: true)"
        }
      },
      "required": ["task_id"]
    },
    "inputsSpec": {
      "required": ["task_id"],
      "optional": ["include_comments", "include_custom_fields"]
    }
  },
  {
    "toolSlug": "ClickUp_CreateTask",
    "toolPurpose": "Create a new task in a ClickUp list with name, description, assignees, priority, and due date.",
    "created_by": "human",
    "parameters": {
      "type": "object",
      "properties": {
        "list_id": {
          "type": "string",
          "description": "ClickUp list ID where task will be created"
        },
        "name": {
          "type": "string",
          "description": "Task title/name (required)"
        },
        "description": {
          "type": "string",
          "description": "Detailed task description (markdown supported)"
        },
        "assignees": {
          "type": "array",
          "description": "Array of assignee user IDs",
          "items": { "type": "string" }
        },
        "priority": {
          "type": "integer",
          "description": "Task priority (1=urgent, 2=high, 3=medium, 4=low)",
          "minimum": 1,
          "maximum": 4
        },
        "due_date": {
          "type": "string",
          "description": "Due date in YYYY-MM-DD format or Unix timestamp in milliseconds"
        },
        "status": {
          "type": "string",
          "description": "Initial task status (e.g., 'to do', 'in progress', 'review', 'done')"
        },
        "parent_task_id": {
          "type": "string",
          "description": "Parent task ID for creating subtasks"
        },
        "notify_all": {
          "type": "boolean",
          "description": "Notify all assignees when task is created (default: true)"
        }
      },
      "required": ["list_id", "name"]
    },
    "inputsSpec": {
      "required": ["list_id", "name"],
      "optional": ["description", "assignees", "priority", "due_date", "status", "parent_task_id", "notify_all"]
    }
  },
  {
