  {
    "toolSlug": "Linear_ListIssues",
    "toolPurpose": "Retrieve issues with optional filters by team, state, assignee, label, and priority. Returns paginated results with issue details including identifiers, status, and assignee information.",
    "created_by": "human",
    "parameters": {
      "type": "object",
      "properties": {
        "teamId": {
          "type": "string",
          "description": "Filter issues by team ID"
        },
        "state": {
          "type": "string",
          "description": "Filter issues by state (e.g., 'Backlog', 'Todo', 'In Progress', 'In Review', 'Done')",
          "enum": ["Backlog", "Todo", "In Progress", "In Review", "Done"]
        },
        "assigneeId": {
          "type": "string",
          "description": "Filter issues assigned to a specific user ID"
        },
        "label": {
          "type": "string",
          "description": "Filter issues by label name"
        },
        "priority": {
          "type": "integer",
          "description": "Filter issues by priority (0=none, 1=urgent, 2=high, 3=medium, 4=low)",
          "minimum": 0,
          "maximum": 4
        },
        "limit": {
          "type": "integer",
          "description": "Maximum number of issues to return (default: 50, max: 250)",
          "minimum": 1,
          "maximum": 250
        }
      },
      "required": []
    },
    "inputsSpec": {
      "required": [],
      "optional": ["teamId", "state", "assigneeId", "label", "priority", "limit"]
    }
  },
