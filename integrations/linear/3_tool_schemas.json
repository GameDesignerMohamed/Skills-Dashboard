        },
        "teamId": {
          "type": "string",
          "description": "ID of the team to assign the issue to"
        },
        "priority": {
          "type": "integer",
          "description": "Issue priority (0=none, 1=urgent, 2=high, 3=medium, 4=low)",
          "minimum": 0,
          "maximum": 4
        },
        "assigneeId": {
          "type": "string",
          "description": "User ID to assign the issue to"
        },
        "labelIds": {
          "type": "array",
          "description": "Array of label IDs to attach to the issue",
          "items": { "type": "string" }
        },
        "projectId": {
          "type": "string",
          "description": "Project ID to associate the issue with"
        }
      },
      "required": ["title", "teamId"]
    },
    "inputsSpec": {
      "required": ["title", "teamId"],
      "optional": ["description", "priority", "assigneeId", "labelIds", "projectId"]
    }
  },
