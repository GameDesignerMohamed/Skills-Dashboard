  {
    "toolSlug": "Linear_CreateIssue",
    "toolPurpose": "Create a new issue in Linear with title, description, team assignment, priority, assignee, and labels. Returns the newly created issue with its identifier and metadata.",
    "created_by": "human",
    "parameters": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Issue title/summary"
        },
        "description": {
          "type": "string",
