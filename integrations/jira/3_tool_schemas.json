[
  {
    "toolSlug": "Jira_SearchIssues",
    "toolPurpose": "Search for Jira issues using JQL (Jira Query Language) with optional pagination and field expansion.",
    "created_by": "human",
    "parameters": {
      "type": "object",
      "properties": {
        "jql": {
          "type": "string",
          "description": "JQL query string (e.g., 'project = PROJ AND status = \"In Progress\"', 'assignee = currentUser() AND type = Bug')"
        },
        "startAt": {
          "type": "integer",
          "description": "Starting index for pagination (default: 0)"
        },
        "maxResults": {
          "type": "integer",
          "description": "Maximum results to return (default: 50, max: 100)"
        },
        "fields": {
          "type": "array",
          "description": "Specific fields to return (e.g., ['key', 'summary', 'status', 'assignee'])",
          "items": { "type": "string" }
        },
        "expand": {
          "type": "string",
          "description": "Additional data to expand (e.g., 'changelog', 'names', 'schema')"
        }
      },
      "required": ["jql"]
    },
    "inputsSpec": {
      "required": ["jql"],
      "optional": ["startAt", "maxResults", "fields", "expand"]
    }
  },
  {
    "toolSlug": "Jira_GetIssue",
