        },
        "fields": {
          "type": "array",
          "description": "Specific fields to return (defaults to all)",
          "items": { "type": "string" }
        },
        "expand": {
          "type": "string",
          "description": "Additional data to expand (e.g., 'changelog', 'comments', 'history')"
        },
        "updateHistory": {
          "type": "boolean",
          "description": "Whether to include change history (default: false)"
        }
      },
      "required": ["issueIdOrKey"]
    },
    "inputsSpec": {
      "required": ["issueIdOrKey"],
      "optional": ["fields", "expand", "updateHistory"]
    }
  },
  {
    "toolSlug": "Jira_CreateIssue",
    "toolPurpose": "Create a new Jira issue with summary, description, issue type, and optional fields like assignee, labels, and components.",
    "created_by": "human",
    "parameters": {
      "type": "object",
      "properties": {
        "projectKey": {
          "type": "string",
          "description": "Project key where the issue will be created (e.g., 'PROJ')"
        },
        "issuetype": {
          "type": "string",
          "description": "Issue type name or ID (e.g., 'Bug', 'Task', 'Story', 'Epic')"
        },
        "summary": {
          "type": "string",
          "description": "Issue summary/title (required)"
        },
        "description": {
          "type": "string",
          "description": "Detailed description (supports ADF - Atlassian Document Format, or plain text)"
        },
        "assignee": {
          "type": "string",
          "description": "Assignee account ID or user key"
        },
        "labels": {
          "type": "array",
          "description": "Array of label names to attach to the issue",
          "items": { "type": "string" }
        },
        "components": {
          "type": "array",
          "description": "Array of component names or IDs",
          "items": { "type": "string" }
        },
        "priority": {
          "type": "string",
          "description": "Priority name (e.g., 'Lowest', 'Low', 'Medium', 'High', 'Highest')"
        },
        "dueDate": {
          "type": "string",
          "description": "Due date in YYYY-MM-DD format"
        },
        "customFields": {
          "type": "object",
          "description": "Additional custom fields as key-value pairs (e.g., {'customfield_10001': 'value'})"
        }
      },
      "required": ["projectKey", "issuetype", "summary"]
    },
    "inputsSpec": {
      "required": ["projectKey", "issuetype", "summary"],
      "optional": ["description", "assignee", "labels", "components", "priority", "dueDate", "customFields"]
    }
  },
